########################################
# Canvas Configuration
########################################

CANVAS_BASE_URL=https://canvas.example.edu
CANVAS_API_TOKEN=changeme
EXCLUDED_TERM_IDS=  # comma-separated canvas term ids
ACCOUNT_ID=1 # recommend do not change

########################################
# Scan Restrictions
########################################

DEFAULT_MAX_FILE_SCAN_MB = 50
DEFAULT_SCAN_TIMEOUT_MINUTES = 15

########################################
# Database
########################################

DATABASE_URL=postgresql://dbuser:dbpass@postgres:5432/ccauditor

########################################
# Redis
########################################

REDIS_URL=redis://redis:6379/0


########################################
# Authentication
########################################

BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=changeme

# restrict new user requests to this domain
ALLOWED_EMAIL_DOMAIN=example.edu


########################################
# Session / Security
########################################

SESSION_TIMEOUT=3600
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCK_TIME=300
PASSWORD_MIN_LENGTH=12

########################################
# Accessibility Standards
########################################

ACCESSIBILITY_STANDARD_VERSION=WCAG 2.2 # valid: WCAG 2.2, WCAG 2.1
ACCESSIBILITY_LEVEL=AA


########################################
# AI Configuration
########################################

AI_ENABLED=true
AI_PROVIDER=ollama

# default models (can be overridden in UI)
AI_MODEL=llama3
EMBEDDING_MODEL=nomic-embed-text
VISION_MODEL=llava

# Ollama endpoint
OLLAMA_HOST=http://ollama:11434


########################################
# External AI Providers (optional)
########################################

OPENAI_API_KEY=
ANTHROPIC_API_KEY=


########################################
# AI Safety Limits
########################################

AI_MAX_REQUESTS_PER_SCAN=200
AI_MAX_REQUESTS_PER_SCAN_MAX=1000

AI_MAX_TOKENS_PER_REQUEST=1500
AI_MAX_TOKENS_PER_REQUEST_MAX=4000


########################################
# Scan Configuration
########################################

SCAN_INCREMENTAL_ENABLED=true
SCAN_INCREMENTAL_THRESHOLD_HOURS=24
SCAN_RETRY_DELAY=30


########################################
# Worker Configuration
########################################

CELERY_WORKER_CONCURRENCY=10
CELERY_WORKER_MAX_TASKS_PER_CHILD=100

CELERY_TASK_TIME_LIMIT=900
CELERY_TASK_SOFT_TIME_LIMIT=870


########################################
# Course Filtering
########################################

# comma-separated Canvas enrollment term IDs
EXCLUDED_TERM_IDS=


########################################
# Infrastructure
########################################

PROMETHEUS_ENABLED=true
GRAFANA_ENABLED=true

########################################
# Video API Keys
########################################

PANOPTO_CLIENT_ID=
PANOPTO_CLIENT_SECRET=
VIMEO_API_TOKEN=
YOUTUBE_API_KEY=

# no https:// or trailing /
PANOPTO_SERVER=panopto.example.com