# Canvas
CANVAS_BASE_URL=https://canvas.example.edu
CANVAS_API_TOKEN=changeme

# Incremental scanning
SCAN_INCREMENTAL_ENABLED=true
SCAN_INCREMENTAL_THRESHOLD_HOURS=24

# Scan concurrency
SCAN_CONCURRENCY_MIN=5
SCAN_CONCURRENCY_MAX=20
SCAN_RETRY_DELAY=30

# Database
DATABASE_URL=postgresql://ccauditor:ccauditor@postgres:5432/ccauditor

# Redis
REDIS_URL=redis://redis:6379/0

# Authentication
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=changeme
ALLOWED_EMAIL_DOMAIN=example.edu

# Security
SESSION_TIMEOUT=3600
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCK_TIME=300
PASSWORD_MIN_LENGTH=12

# AI Configuration
AI_ENABLED=true
AI_PROVIDER=ollama
AI_MODEL=llama3
EMBEDDING_MODEL=nomic-embed-text
VISION_MODEL=llava

# AI Safety Limits
AI_MAX_REQUESTS_PER_SCAN=200
AI_MAX_REQUESTS_PER_SCAN_MAX=1000
AI_MAX_TOKENS_PER_REQUEST=1500
AI_MAX_TOKENS_PER_REQUEST_MAX=4000

# Logging
LOG_DESTINATION=stdout

# Scan Limits
MAX_FILE_SCAN_MB=50
SCAN_TIMEOUT_MINUTES=15

# Celery Worker Settings
CELERY_WORKER_CONCURRENCY=10
CELERY_WORKER_MAX_TASKS_PER_CHILD=100
CELERY_TASK_TIME_LIMIT=900
CELERY_TASK_SOFT_TIME_LIMIT=870

# Ollama
OLLAMA_HOST=http://ollama:11434

# OpenAI
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=