{
  "title": "Scan Monitoring",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "stat",
      "title": "Total Course Scans",
      "targets": [
        { "expr": "ccauditor_course_scans_total" }
      ]
    },
    {
      "type": "stat",
      "title": "Scan Failures",
      "targets": [
        { "expr": "ccauditor_scan_failures_total" }
      ]
    },
    {
      "type": "graph",
      "title": "Scan Rate",
      "targets": [
        { "expr": "rate(ccauditor_course_scans_total[5m])" }
      ]
    },
    {
      "type": "graph",
      "title": "Scan Duration",
      "targets": [
        { "expr": "rate(ccauditor_scan_duration_seconds_sum[5m])" }
      ]
    }
  ]
}