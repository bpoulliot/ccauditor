{
  "title": "CCAuditor Accessibility Analytics",
  "panels": [

    {
      "type": "stat",
      "title": "Total Courses Scanned",
      "targets": [
        { "expr": "ccauditor_course_scans_total" }
      ]
    },

    {
      "type": "graph",
      "title": "Average Accessibility Risk Score",
      "targets": [
        { "expr": "avg(ccauditor_course_risk_score)" }
      ]
    },

    {
      "type": "graph",
      "title": "WCAG Violations by Type",
      "targets": [
        { "expr": "sum by(issue_type) (ccauditor_accessibility_issues_total)" }
      ]
    },

    {
      "type": "graph",
      "title": "Caption Remediation Hours",
      "targets": [
        { "expr": "sum(ccauditor_caption_remediation_hours)" }
      ]
    },

    {
      "type": "graph",
      "title": "Duplicate Content Detected",
      "targets": [
        { "expr": "sum(ccauditor_duplicate_content_total)" }
      ]
    },

    {
      "type": "graph",
      "title": "Broken Links",
      "targets": [
        { "expr": "sum(ccauditor_broken_links_total)" }
      ]
    },

    {
      "type": "graph",
      "title": "Files Missing Accessibility Structure",
      "targets": [
        { "expr": "sum(ccauditor_file_accessibility_issues_total)" }
      ]
    },

    {
      "type": "graph",
      "title": "Caption Coverage",
      "targets": [
        { "expr": "sum(ccauditor_videos_captioned_total) / sum(ccauditor_videos_total)" }
      ]
    },

    {
      "type": "graph",
      "title": "Courses With High Risk Score",
      "targets": [
        { "expr": "count(ccauditor_course_risk_score > 10)" }
      ]
    }

  ],
  "schemaVersion": 36,
  "version": 1,
  "refresh": "10s"
}