{
  "title": "CCAuditor Scan Monitoring",
  "timezone": "browser",
  "panels": [

    {
      "type": "stat",
      "title": "Total Course Scans",
      "targets": [
        {
          "expr": "ccauditor_course_scans_total"
        }
      ]
    },

    {
      "type": "stat",
      "title": "Scan Failures",
      "targets": [
        {
          "expr": "ccauditor_scan_failures_total"
        }
      ]
    },

    {
      "type": "graph",
      "title": "Scan Duration (seconds)",
      "targets": [
        {
          "expr": "rate(ccauditor_scan_duration_seconds_sum[5m])"
        }
      ]
    },

    {
      "type": "graph",
      "title": "Scan Rate",
      "targets": [
        {
          "expr": "rate(ccauditor_course_scans_total[5m])"
        }
      ]
    },

    {
      "type": "stat",
      "title": "Active Scan Workers",
      "targets": [
        {
          "expr": "celery_workers_active"
        }
      ]
    },

    {
      "type": "graph",
      "title": "Redis Queue Depth (Scans)",
      "targets": [
        {
          "expr": "redis_queue_length{queue=\"scans\"}"
        }
      ]
    },

    {
      "type": "graph",
      "title": "Redis Queue Depth (AI)",
      "targets": [
        {
          "expr": "redis_queue_length{queue=\"ai\"}"
        }
      ]
    },

    {
      "type": "graph",
      "title": "Redis Queue Depth (Hygiene)",
      "targets": [
        {
          "expr": "redis_queue_length{queue=\"hygiene\"}"
        }
      ]
    },

    {
      "type": "graph",
      "title": "Scan Failure Rate",
      "targets": [
        {
          "expr": "rate(ccauditor_scan_failures_total[5m])"
        }
      ]
    },

    {
      "type": "graph",
      "title": "Average Scan Duration",
      "targets": [
        {
          "expr": "rate(ccauditor_scan_duration_seconds_sum[5m]) / rate(ccauditor_scan_duration_seconds_count[5m])"
        }
      ]
    },

    {
      "type": "table",
      "title": "Recent Scan Activity",
      "targets": [
        {
          "expr": "ccauditor_course_scans_total"
        }
      ]
    },

    {
      "type": "graph",
      "title": "AI Task Rate",
      "targets": [
        {
          "expr": "rate(celery_tasks_total{queue=\"ai\"}[5m])"
        }
      ]
    },

    {
      "type": "graph",
      "title": "Hygiene Task Rate",
      "targets": [
        {
          "expr": "rate(celery_tasks_total{queue=\"hygiene\"}[5m])"
        }
      ]
    }

  ],
  "schemaVersion": 36,
  "version": 1,
  "refresh": "10s"
}